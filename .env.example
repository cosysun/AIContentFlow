# AIContentFlow 环境变量配置示例
# 复制此文件为 .env 并填入真实的API Key

# Brave Search API Key
# 获取地址：https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# OpenAI API Key（可选）
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Notion 配置
# Token 获取地址：https://www.notion.so/my-integrations（创建 Integration 后获取）
NOTION_TOKEN=your_notion_token_here
# 父页面 ID（在 Notion 页面 URL 中获取，格式：32位十六进制）
NOTION_PARENT_PAGE_ID=your_parent_page_id_here
# 归档索引页 ID（首次运行后自动生成，或手动指定）
NOTION_INDEX_PAGE_ID=your_index_page_id_here
# 草稿箱页面 ID（文章发布前暂存区，发布后归档到正式内容库）
NOTION_DRAFTS_PAGE_ID=your_drafts_page_id_here
# 草稿箱专属子目录（可选，不填则统一使用 NOTION_DRAFTS_PAGE_ID）
NOTION_DRAFTS_WECHAT_PAGE_ID=your_drafts_wechat_page_id_here
NOTION_DRAFTS_XHS_PAGE_ID=your_drafts_xhs_page_id_here
# 正式内容库专属子目录（可选，不填则统一使用 NOTION_PARENT_PAGE_ID）
NOTION_ARCHIVE_WECHAT_PAGE_ID=your_archive_wechat_page_id_here
NOTION_ARCHIVE_XHS_PAGE_ID=your_archive_xhs_page_id_here

# 其他配置
TOP_TOPICS=5

# 微信公众号配置
# AppID 和 AppSecret 在微信公众平台 → 开发 → 基本配置 中获取
WECHAT_APPID=your_wechat_appid_here
WECHAT_APPSECRET=your_wechat_appsecret_here
